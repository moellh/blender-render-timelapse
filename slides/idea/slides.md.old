# Existing Work

<script setup>
import { onMounted, onUnmounted, nextTick } from 'vue'

let intervals = []
let observer = null

onMounted(() => {
  nextTick(() => {
    const panels = document.querySelectorAll('.scroll-panel')
    
    panels.forEach(panel => {
      let autoScroll = true
      const content = panel.querySelector('.scroll-content')
      const totalH = content.scrollHeight / 2

      const interval = setInterval(() => {
        if (!autoScroll) return
        panel.scrollTop += 0.8
        if (panel.scrollTop >= totalH - panel.clientHeight) {
          panel.scrollTop = 0
        }
      }, 30)
      intervals.push(interval)

      const pause = () => { autoScroll = false }
      panel.addEventListener('wheel', pause, { passive: true })
      panel.addEventListener('touchstart', pause, { passive: true })
    })

    const slide = document.querySelector('.slidev-slide')
    if (slide) {
      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            intervals.forEach(id => clearInterval(id))
            intervals = []
            panels.forEach(p => { p.scrollTop = 0 })
            panels.forEach(panel => {
              let autoScroll = true
              const content = panel.querySelector('.scroll-content')
              const totalH = content.scrollHeight / 2
              const interval = setInterval(() => {
                if (!autoScroll) return
                panel.scrollTop += 0.8
                if (panel.scrollTop >= totalH - panel.clientHeight) {
                  panel.scrollTop = 0
                }
              }, 30)
              intervals.push(interval)
              const pause = () => { autoScroll = false }
              panel.addEventListener('wheel', pause, { passive: true })
              panel.addEventListener('touchstart', pause, { passive: true })
            })
          }
        })
      })
      observer.observe(slide)
    }
  })
})

onUnmounted(() => {
  intervals.forEach(id => clearInterval(id))
  if (observer) observer.disconnect()
})
</script>

